# Path
# ref: https://qiita.com/magicant/items/d3bb7ea1192e63fba850
export PATH="$HOME/.local/bin:$PATH"

# g<GNU CMD> series
export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"
export PATH="/opt/homebrew/opt/grep/libexec/gnubin:$PATH"
export PATH="/opt/homebrew/opt/gnu-sed/libexec/gnubin:$PATH"
# brew
eval "$(/opt/homebrew/bin/brew shellenv)"

# Envs used for .zshrc
# Prefer VS Code for visual editing while keeping nano as a terminal-safe fallback.
export VISUAL="code --wait"
export EDITOR="nano"
export FILTER_CMD="fzf"
export CONFIGS_COMMON_ZSH="$HOME/configs/common/zsh"
__mac_specific_zsh_var="CONFIGS_${OSTYPE//[^a-zA-Z0-9]/_}_ZSH"
export ${__mac_specific_zsh_var}="$HOME/configs/Mac"
unset -v __mac_specific_zsh_var
