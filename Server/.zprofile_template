export PATH="$HOME/.local/bin:$PATH"

# Envs used for .zshrc
export VISUAL="code --wait"
export EDITOR="nano"
export LESS='-F -g -i -M -R -W -X -z-4 -x4 --mouse --wheel-lines=8'
export FILTER_CMD="fzf"
export CONFIGS_COMMON_ZSH="$HOME/configs/common/zsh"
export __os_specific_zsh_var="CONFIGS_${OSTYPE//[^a-zA-Z0-9]/_}_ZSH"
export ${__os_specific_zsh_var}="$HOME/configs/Server"
unset -v __os_specific_zsh_var
