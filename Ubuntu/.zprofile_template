export PATH="$HOME/.local/bin:$PATH"

# CUDA
export PATH=/usr/local/cuda:/usr/local/cuda/bin:$PATH
export LD_LIBRARY_PATH=/usr/local/lib:/usr/local/cuda/lib64:$LD_LIBRARY_PATH

# Envs used for .zshrc
export FILTER_CMD="fzf"
export CONFIGS_COMMON_ZSH="$HOME/configs/common/zsh"
export __os_specific_zsh_var="CONFIGS_${OSTYPE//[^a-zA-Z0-9]/_}_ZSH"
export ${__os_specific_zsh_var}="$HOME/configs/Ubuntu"
unset -v __os_specific_zsh_var

# nvm
# ref: https://developers.openai.com/codex/windows
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
