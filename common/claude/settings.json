{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env*)",
      "Read(./**/.env)",
      "Read(./**/.env*)",
      "Read(./.direnv)",
      "Read(./.direnv/**)",
      "Read(./**/.direnv)",
      "Read(./**/.direnv/**)",
      "Read(./secrets)",
      "Read(./secrets/**)",
      "Read(./**/secrets)",
      "Read(./**/secrets/**)",
      "Read(~/.netrc)",
      "Read(~/.aws/credentials)",
      "Read(~/**/huggingface/token)"
    ],
    "defaultMode": "auto",
    "disableBypassPermissionsMode": "disable"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*"
      ]
    },
    "filesystem": {
      "denyRead": [
        "./.env",
        "./.env*",
        "./**/.env",
        "./**/.env*",
        "./.direnv",
        "./.direnv/**",
        "./**/.direnv",
        "./**/.direnv/**",
        "./secrets",
        "./secrets/**",
        "./**/secrets",
        "./**/secrets/**",
        "~/.netrc",
        "~/.aws/credentials",
        "~/**/huggingface/token"
      ]
    }
  },
  "effortLevel": "xhigh",
  "skipAutoPermissionPrompt": true
}
